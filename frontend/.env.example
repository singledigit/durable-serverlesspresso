# API Configuration
# Base URL for the REST API Gateway
VITE_API_BASE_URL=https://api.example.com

# AppSync Events Configuration
# Real-time WebSocket updates for order status changes
# These values will be available after deploying the backend infrastructure
# Leave empty for development mode (real-time updates will be disabled)
VITE_APPSYNC_EVENTS_URL=https://events.appsync-api.example.com
VITE_APPSYNC_EVENTS_API_KEY=da2-xxxxxxxxxxxxx

# Event Configuration
# The event ID for the coffee ordering system
VITE_EVENT_ID=reinvent-2025
